<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EncryptedChat.LanModeWindow"
        Title="LAN Mode" Width="800" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid Margin="40,30" RowDefinitions="Auto,*,Auto">

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,16">
                <Button Content="← Back" Click="Back_Click"
                        Background="#16213e" Foreground="#eaeaea"
                        BorderThickness="0" Padding="15,6"/>
                <TextBlock Text="🏠 LAN Mode" FontSize="24" FontWeight="Bold"
                           Foreground="#00ff88" VerticalAlignment="Center"/>
            </StackPanel>
            <Border Background="#16213e" Padding="0,12" Margin="0,0,0,20">
                <TextBlock x:Name="IpLabel" Text="📡 Your LAN IP: detecting…"
                           FontWeight="Bold" Foreground="#00ff88"
                           HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="ServerListBox"
                 Background="#16213e" BorderBrush="#0f3460" BorderThickness="1"
                 Padding="8" DoubleTapped="ServerList_DoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#eaeaea"/>
                        <TextBlock Foreground="#888888">
                            <Run Text="IP: "/><Run Text="{Binding Ip}"/>
                            <Run Text="  |  Users: "/><Run Text="{Binding Users}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="10" Margin="0,16,0,0">
            <Button Content="🔄 Refresh" Click="Refresh_Click"
                    Background="#0f3460" Foreground="White" BorderThickness="0" Padding="20,10"/>
            <Button Content="🔗 Direct Connect" Click="DirectConnect_Click"
                    Background="#e94560" Foreground="White" BorderThickness="0" Padding="20,10"/>
        </StackPanel>
    </Grid>
</Window>
